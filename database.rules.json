{
  "rules": {
    ".read": false,
    ".write": false,
    "properties": {
      ".read": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'admin'",
      "property_001": {
        ".read": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties/property_001/members').child(auth.uid).exists())",
        "rooms": {
          "room_001": {
            "latest": {
              ".write": "auth != null && (auth.provider === 'anonymous' || (auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === 'property_001' && auth.token.roomId === 'room_001'))"
            },
            "devices": {
              ".read": "auth != null && (auth.provider === 'anonymous' || (auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === 'property_001' && auth.token.roomId === 'room_001'))",
              ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties/property_001/members').child(auth.uid).exists())"
            },
            "settings": {
              "automationEnabled": {
                ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties/property_001/members').child(auth.uid).exists())",
                ".validate": "newData.isBoolean()"
              }
            },
            "evaluationRuns": {
              "$runId": {
                ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties/property_001/members').child(auth.uid).exists())",
                "label": { ".validate": "newData.val() === 'baseline' || newData.val() === 'ecostay'" },
                "automationEnabled": { ".validate": "newData.isBoolean()" },
                "startedAt": { ".validate": "newData.isNumber()" },
                "endedAt": { ".validate": "newData.isNumber()" },
                "startEnergyKWh": { ".validate": "newData.isNumber()" },
                "endEnergyKWh": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              }
            }
          },
          "$roomId": {
            "latest": {
              ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === 'property_001' && auth.token.roomId === $roomId"
            },
            "devices": {
              ".read": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === 'property_001' && auth.token.roomId === $roomId"
            },
            "evaluationRuns": {
              "$runId": {
                ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties/property_001/members').child(auth.uid).exists())",
                "label": { ".validate": "newData.val() === 'baseline' || newData.val() === 'ecostay'" },
                "automationEnabled": { ".validate": "newData.isBoolean()" },
                "startedAt": { ".validate": "newData.isNumber()" },
                "endedAt": { ".validate": "newData.isNumber()" },
                "startEnergyKWh": { ".validate": "newData.isNumber()" },
                "endEnergyKWh": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              }
            }
          }
        },
        "history": {
          ".write": "auth != null && auth.provider === 'anonymous'",
          "$historyId": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === 'property_001' && auth.token.roomId === newData.child('roomId').val() && !data.exists() && newData.exists()"
          }
        },
        "energyHistory": {
          "$roomId": {
            ".indexOn": "sampledAt"
          }
        },
        "alerts": {
          "$alertId": {
            "acknowledgedBy": {
              ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties/property_001/members').child(auth.uid).exists())",
              ".validate": "newData.val() === auth.uid"
            },
            "acknowledgedAt": {
              ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties/property_001/members').child(auth.uid).exists())",
              ".validate": "newData.isNumber()"
            }
          }
        },
        "settings": {
          "tariffCategory": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'admin'",
            ".validate": "newData.isString() && (newData.val() === 'D-1' || newData.val() === 'GP-1' || newData.val() === 'H-1')"
          },
          "circuitWattages": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'admin'",
            ".validate": "newData.hasChildren(['lights', 'exhaustFan'])",
            "lights": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "exhaustFan": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "$other": { ".validate": false }
          },
          "alertThresholds": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'admin'",
            ".validate": "newData.hasChildren(['temperatureC', 'waterLevelPct', 'acPowerThresholdW'])",
            "temperatureC": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50" },
            "waterLevelPct": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
            "acPowerThresholdW": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000" },
            "$other": { ".validate": false }
          }
        }
      },
      "$propertyId": {
        ".read": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties').child($propertyId).child('members').child(auth.uid).exists())",
        "rooms": {
          "$roomId": {
            "latest": {
              ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === $propertyId && auth.token.roomId === $roomId"
            },
            "devices": {
              ".read": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === $propertyId && auth.token.roomId === $roomId",
              ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties').child($propertyId).child('members').child(auth.uid).exists())"
            },
            "settings": {
              "automationEnabled": {
                ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties').child($propertyId).child('members').child(auth.uid).exists())",
                ".validate": "newData.isBoolean()"
              }
            },
            "evaluationRuns": {
              "$runId": {
                ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties').child($propertyId).child('members').child(auth.uid).exists())",
                "label": { ".validate": "newData.val() === 'baseline' || newData.val() === 'ecostay'" },
                "automationEnabled": { ".validate": "newData.isBoolean()" },
                "startedAt": { ".validate": "newData.isNumber()" },
                "endedAt": { ".validate": "newData.isNumber()" },
                "startEnergyKWh": { ".validate": "newData.isNumber()" },
                "endEnergyKWh": { ".validate": "newData.isNumber()" },
                "$other": { ".validate": false }
              }
            }
          }
        },
        "history": {
          "$historyId": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'device' && auth.token.propertyId === $propertyId && auth.token.roomId === newData.child('roomId').val() && !data.exists() && newData.exists()"
          }
        },
        "energyHistory": {
          "$roomId": {
            ".indexOn": "sampledAt"
          }
        },
        "alerts": {
          "$alertId": {
            "acknowledgedBy": {
              ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties').child($propertyId).child('members').child(auth.uid).exists())",
              ".validate": "newData.val() === auth.uid"
            },
            "acknowledgedAt": {
              ".write": "auth != null && auth.provider !== 'anonymous' && (auth.token.role === 'admin' || root.child('properties').child($propertyId).child('members').child(auth.uid).exists())",
              ".validate": "newData.isNumber()"
            }
          }
        },
        "settings": {
          "tariffCategory": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'admin'",
            ".validate": "newData.isString() && (newData.val() === 'D-1' || newData.val() === 'GP-1' || newData.val() === 'H-1')"
          },
          "circuitWattages": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'admin'",
            ".validate": "newData.hasChildren(['lights', 'exhaustFan'])",
            "lights": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "exhaustFan": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "$other": { ".validate": false }
          },
          "alertThresholds": {
            ".write": "auth != null && auth.provider !== 'anonymous' && auth.token.role === 'admin'",
            ".validate": "newData.hasChildren(['temperatureC', 'waterLevelPct', 'acPowerThresholdW'])",
            "temperatureC": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 50" },
            "waterLevelPct": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
            "acPowerThresholdW": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000" },
            "$other": { ".validate": false }
          }
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    }
  }
}
